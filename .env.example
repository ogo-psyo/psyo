# Canonical public app URL used for auth email redirects
NEXT_PUBLIC_APP_URL=https://pso-mvp-uglanovrms-projects.vercel.app
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=psyoo_bot
APP_ENV=development
RELEASE_SHA=

# Supabase browser/server URL and browser anon key
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Server-only key. Never expose to client bundles or chat.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Optional: enables avatar generation endpoint
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Telegram Mini App auth. Server validates initData and returns HMAC psyo_user_id.
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_BOT_USERNAME=psyoo_bot
PSYO_ID_PEPPER=CHANGE_ME_LONG_RANDOM_SECRET
PSYO_SESSION_SIGNING_KEY=CHANGE_ME_LONG_RANDOM_SESSION_SECRET
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=86400

# Optional Better Auth migration path for Telegram Mini App auth.
# Requires direct Postgres access, not the Supabase REST URL.
BETTER_AUTH_URL=https://pso-mvp-uglanovrms-projects.vercel.app
BETTER_AUTH_SECRET=CHANGE_ME_LONG_RANDOM_BETTER_AUTH_SECRET
BETTER_AUTH_DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DB

# Optional: Telegram webhook hardening for bot chat replies.
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_LONG_RANDOM_SECRET

# RC1 billing is disabled until owner/legal release gates are approved.
SUBSCRIPTION_PRICE_STARS=199
SUBSCRIPTION_PERIOD_SECONDS=2592000
BILLING_ENABLED=false
PLUS_PAYWALL_ENABLED=false
FOUNDER_PRICE_ENABLED=false

# RC1 feature flags / kill switches
WEEKLY_SUMMARY_ENABLED=false
CAREGIVER_INVITES_ENABLED=false
PDF_EXPORT_ENABLED=true
BROWSER_QA_ENABLED=false
LOST_MODE_ENABLED=false
AI_QA_ENABLED=false
AVATAR_GENERATION_ENABLED=false
TELEGRAM_NOTIFICATIONS_ENABLED=false
NEW_INVOICES_ENABLED=false
PUBLIC_SHARING_ENABLED=true
UPLOADS_ENABLED=false

# Legal/support
SUPPORT_CONTACT=TBD
PRIVACY_POLICY_VERSION=draft
TERMS_VERSION=draft
